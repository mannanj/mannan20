{
  "name": "mannan",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "lsof -ti:3847 -sTCP:LISTEN | xargs kill -9 2>/dev/null; rm -rf .next; next dev --turbopack -p 3847",
    "build": "next build",
    "start": "next start",
    "test:e2e": "bunx playwright test",
    "test:unit": "bun test src",
    "typecheck": "tsc --noEmit",
    "unicorn:build": "node scripts/apply-unicorn-transforms.mjs",
    "postinstall": "node scripts/apply-unicorn-transforms.mjs",
    "visits:recent": "cd visits-worker && bun run db:recent",
    "visits:top": "cd visits-worker && bun run db:top",
    "visits:deploy": "cd visits-worker && bun run deploy",
    "visits:tail": "cd visits-worker && bun run tail",
    "mcp:build": "bun scripts/build-mcp-data.mjs",
    "mcp:check": "bun scripts/build-mcp-data.mjs --check",
    "mcp:test": "cd mcp-worker && bun run test",
    "mcp:deploy": "bun scripts/build-mcp-data.mjs && cd mcp-worker && bun run deploy",
    "mcp:smoke": "cd mcp-worker && bun run smoke"
  },
  "dependencies": {
    "@cloudflare/realtimekit": "2.0.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tailwindcss/postcss": "^4.1.14",
    "@uiw/react-md-editor": "^4.0.11",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "@xyflow/react": "^12.10.2",
    "@zumer/snapdom": "^2.9.0",
    "howler": "^2.2.4",
    "next": "^15.5.20",
    "postcss": "^8.5.16",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "stripe": "^20.3.0",
    "tailwindcss": "^4.1.14",
    "three": "^0.182.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@imgly/background-removal-node": "^1.4.5",
    "@neplex/vectorizer": "^0.0.5",
    "@playwright/test": "^1.58.2",
    "@types/bun": "^1.3.14",
    "@types/howler": "^2.2.12",
    "@types/node": "^20.17.19",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.182.0",
    "@types/youtube": "^0.1.2",
    "typescript": "~5.8.3"
  }
}
